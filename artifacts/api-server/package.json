{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/kill-port.mjs 2>/dev/null; sleep 1; export NODE_ENV=development && (pnpm run build || (echo '\\n\\033[41m\\033[97m  DEV ABORTED: API server build failed — server NOT restarted, dist cũ vẫn đang chạy nếu workflow trước đó còn sống. Xem log build phía trên.  \\033[0m\\n' && exit 1)) && pnpm run start",
    "build": "node ./scripts/check-duplicate-functions.mjs && node ./build.mjs",
    "start": "node --env-file=../../.env --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@google-cloud/storage": "^7.19.0",
    "@types/multer": "^2.1.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "express": "^5",
    "google-auth-library": "^10.6.2",
    "multer": "^2.1.1",
    "openai": "^4",
    "pino": "^9",
    "pino-http": "^10",
    "web-push": "^3.6.7",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/web-push": "^3.6.4",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "vitest": "^4.1.4"
  }
}
