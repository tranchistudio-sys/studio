# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules
.pnpm-store

# macOS resource forks / junk
._*
.DS_Store

# local temp
-r
-rq
_*.txt
_build.log

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# Secrets & environment
.env
.env.*
!.env.example

# Database exports
downloads/*.sql
downloads/*.sql.gz
downloads/*.zip

# Local uploaded files (runtime)
artifacts/data/object-storage/uploads/

# Customer-uploaded object storage (runtime) — ignore contents, keep dir
artifacts/api-server/data/object-storage/uploads/*
!artifacts/api-server/data/object-storage/uploads/.gitkeep
exports/*.sql

# Backup archives (DB dumps + customer images) — NEVER commit
*.tar.gz
*.tgz
exports/*.zip

# CMS / public uploaded images (runtime, not source)
artifacts/amazing-studio/public/uploads/

# Claude Code / local session artifacts (machine-specific, not source)
.claude/
.agents/
.canvas/
