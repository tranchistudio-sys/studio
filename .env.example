DATABASE_URL=
PORT=3000
NODE_ENV=development
LOCAL_OBJECT_STORAGE_DIR=

# Facebook Messenger: bộ não ChatGPT/OpenAI cũ. false = tắt (mặc định), 1/true = bật.
LEGACY_FB_BOT_ENABLED=false

# Claude (bộ não sale mới) — Giai đoạn 1: tư vấn Messenger
CLAUDE_FB_BOT_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# URL website công khai để Hoa gửi link (bảng giá/bộ ảnh/concept) cho khách. VD: https://amazingstudio.vn
# PUBLIC_APP_URL=

# ─── AI PROVIDER FALLBACK (tổng đài AI dùng chung) ───────────────────────────
# Provider chính. claude (mặc định) | openai | gemini.
# Có thể đổi runtime trong AI Settings (lưu DB) — biến này chỉ là mặc định ban đầu.
AI_PROVIDER=claude
# Công tắc giữ provider cũ để rollback (mặc định false = không gọi nếu Claude đang chạy).
LEGACY_OPENAI_ENABLED=false
LEGACY_GEMINI_ENABLED=false

# OpenAI (dự phòng 1). Key đọc từ DB settings.openai_api_key → AI_INTEGRATIONS_OPENAI_API_KEY → OPENAI_API_KEY.
# OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=
# Model OpenAI khi fallback. Bỏ trống = tự đoán (gateway→gpt-5.2, OpenAI thật→gpt-4o-mini).
# OPENAI_FALLBACK_MODEL=
# Gemini (dự phòng 2 — để dành, chưa bật). Có key thì adapter mới chạy.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
