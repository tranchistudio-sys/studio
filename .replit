modules = ["nodejs-24", "python-3.11", "postgresql-16"]

# Deploy = application router (Replit tự khám phá artifact qua .replit-artifact/).
# Route theo `paths` trong từng artifacts/<x>/.replit-artifact/artifact.toml:
#   api-server (:8080)  → /api + /mcp + OAuth (/authorize /token /register /revoke /.well-known)
#   amazing-studio      → /  (frontend tĩnh, SPA fallback)
# ĐỪNG đổi sang single-process ở đây: Replit bỏ qua build/run root khi có artifact,
# nên muốn cho /mcp về backend phải sửa `paths` của api-server (KHÔNG phải file này).
[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test"

[[workflows.workflow]]
name = "test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["photofield"]

[userenv]

[userenv.development]
ENABLE_AI_TEST_FOLLOWUP = "true"

[userenv.shared]
VAPID_PUBLIC_KEY = "BE8WARUXqXspGH0VJiz2kJlSqcFHeo2SgFaKbrz7lus3XEZbw5KnGYJOSBKxVEGxcVoDI5be5SQXBWfE8iu_ZvY"
VAPID_EMAIL = "mailto:admin@amazingstudio.vn"
